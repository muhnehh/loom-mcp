{
  "name": "@loom-mcp/server",
  "version": "0.6.0",
  "description": "The universal context compiler for AI coding agents. 97.75% token reduction, GPU embeddings, compact wire format, 32+ tools. Free forever.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muhnehh/loom-mcp.git"
  },
  "homepage": "https://github.com/muhnehh/loom-mcp",
  "bugs": {
    "url": "https://github.com/muhnehh/loom-mcp/issues"
  },
  "author": "LoomMCP <loom@mcp.sh>",
  "keywords": [
    "mcp",
    "context",
    "token-optimization",
    "token-reduction",
    "claude",
    "claude-code",
    "ai-agents",
    "coding-assistant",
    "cursor",
    "context-compiler",
    "gpu",
    "embeddings"
  ],
  "bin": {
    "loom-mcp": "dist/index.js",
    "loom": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "node --test __tests__/*.test.mjs",
    "benchmark": "node eval/benchmark.js .",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.1.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.6.0",
    "express": "^5.2.1",
    "glob": "^11.0.0",
    "tiktoken": "^1.0.22",
    "tree-sitter": "^0.22.0",
    "tree-sitter-bash": "^0.25.1",
    "tree-sitter-c": "^0.21.4",
    "tree-sitter-cpp": "^0.21.0",
    "tree-sitter-dart": "^1.0.0",
    "tree-sitter-go": "^0.23.0",
    "tree-sitter-java": "^0.21.0",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-ruby": "^0.21.0",
    "tree-sitter-rust": "^0.23.0",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-typescript": "^0.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
