{
  "name": "@loom-mcp/server",
  "version": "0.4.0",
  "description": "The universal context compiler for AI coding agents. 95% token reduction, cross-session memory, live dashboard, 17 tools. Works with Claude Code, Cursor, VS Code, Codex, and all MCP clients.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muhnehh/loom-mcp.git"
  },
  "homepage": "https://github.com/muhnehh/loom-mcp",
  "bugs": {
    "url": "https://github.com/muhnehh/loom-mcp/issues"
  },
  "author": "LoomMCP <loom@mcp.sh>",
  "keywords": [
    "mcp",
    "context",
    "token-optimization",
    "token-reduction",
    "claude",
    "claude-code",
    "ai-agents",
    "coding-assistant",
    "cursor",
    "context-compiler"
  ],
  "bin": {
    "loom-mcp": "dist/index.js",
    "loom": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "node --test __tests__/*.test.mjs",
    "benchmark": "node eval/benchmark.js .",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.1.0",
    "express": "^5.2.1",
    "glob": "^11.0.0",
    "tree-sitter": "^0.22.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-python": "^0.23.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "files": [
    "dist",
    "prompts",
    "eval",
    "packs",
    "README.md",
    "SETUP.md",
    "CLAUDE.md"
  ]
}
