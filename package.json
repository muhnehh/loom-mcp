  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "files": [
    "dist",
    "prompts",
    "eval",
    "packs",
    "README.md",
    "SETUP.md",
    "SUPPORT.md",
    "CLAUDE.md"
